{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com",
    "temperature": 0.3,
    "max_tokens": 4096,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.example.com",
    "smtp_port": 465,
    "imap_server": "imap.example.com",
    "imap_port": 993,
    "email_address": "noreply@example.com",
    "sender_name": "Horizon Daily"
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 15,
      "min_score": 80
    },
    "rss": [
      {
        "name": "36Kr",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "china-tech"
      },
      {
        "name": "Ben's Bites",
        "url": "https://bensbites.beehiiv.com/feed",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "The Verge - AI",
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      }
    ],
    "github": [
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "claude-code",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "codex",
        "enabled": true
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        }
      ],
      "fetch_comments": 3
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  }
}
